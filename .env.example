# Environment variables for the ODOT Title Forms app.
# On Railway, set these under the service's "Variables" tab.
# Defaults (when unset) are fine for local development.

# Persist the SQLite DB and generated files on a Railway Volume.
# Create a Volume mounted at /data, then point these at it:
TITLEAPP_DATA_DIR=/data/db
TITLEAPP_OUTPUT_DIR=/data/output

# Required in production (served over HTTPS) so session cookies are marked Secure.
# Leave unset / 0 for local http development.
TITLEAPP_SECURE_COOKIES=1
